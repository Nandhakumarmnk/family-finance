rules_version = '2';

// Security rules for Family Finance's Cloud Storage (receipt photos, exported
// PDF reports, profile pictures).
//
// Model: every file lives under users/{uid}/… and is private to that signed-in
// user — the same "your workbook is yours alone" model as the Firestore
// users/{uid} document. Nothing else is readable or writable, so one user can
// never reach another's receipts or reports.
//
// Uploads are capped in size and restricted to images / PDFs so the bucket
// can't be used to stash arbitrary large files.
//
// Publish in: Firebase console → Storage → Rules → Publish.
service firebase.storage {
  match /b/{bucket}/o {

    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024 // 10 MB max
                   && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
