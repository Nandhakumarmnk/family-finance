rules_version = '2';

// Security rules for Family Finance's free Firestore backend.
//
// Model:
//  * Personal data (users/{uid}) is private to its owner.
//  * A family is reachable only by knowing its secret **family code** (the
//    document id, e.g. FAM-7KQ4-9XPM) — you can fetch a family by its exact id
//    but can NEVER list all families, so codes can't be enumerated.
//  * The user who creates a family becomes its **head** (`ownerEmail`). That
//    field is set once at creation and can NEVER change — nobody can promote
//    themselves to head, even if they know the code.
//  * Access to a family's finances requires being in `memberEmails`. Only the
//    HEAD edits that list (and the members/roles roster), so a code-holder can
//    only *request* to join — the head must approve them.
//  * Approved members can read the family and read/write its shared finances
//    (wallet + ledger), but can NOT touch membership or roles.
//
// Paste these in: Firebase console -> Firestore Database -> Rules -> Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function email() {
      return request.auth.token.email;
    }

    // --- Personal workbook: strictly the signed-in owner -------------------
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      // Receipt photos live here as base64 — one document per expense — so
      // attachments need no Cloud Storage bucket (which would force Blaze).
      // Same owner-only access as the workbook above.
      match /receipts/{docId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    // --- Shared family workbook --------------------------------------------
    match /families/{familyId} {

      // Evaluated against the family doc itself (family-doc reads/writes).
      function isOwner() {
        return signedIn() && resource.data.ownerEmail == email();
      }
      function isMember() {
        return signedIn()
          && resource.data.memberEmails is list
          && email() in resource.data.memberEmails;
      }
      // The head (owner) can never be reassigned after creation.
      function ownerUnchanged() {
        return request.resource.data.ownerEmail == resource.data.ownerEmail;
      }
      // A family created before `ownerEmail` existed (legacy docs) has no head
      // recorded server-side, so every head-only write would be blocked forever
      // — even a corrective one. Detect that ownerless state so a current member
      // can adopt it exactly once (see the `update` rule below).
      function ownerless() {
        return !('ownerEmail' in resource.data)
          || resource.data.ownerEmail == null
          || resource.data.ownerEmail == '';
      }
      function claimingSelfAsOwner() {
        return request.resource.data.ownerEmail == email();
      }

      // Subcollection rules can't see the parent via `resource`, so fetch it.
      function familyData() {
        return get(/databases/$(database)/documents/families/$(familyId)).data;
      }
      function isFamilyOwner() {
        return signedIn() && familyData().ownerEmail == email();
      }
      function isFamilyMember() {
        return signedIn()
          && familyData().memberEmails is list
          && email() in familyData().memberEmails;
      }

      // Fetch a family by its EXACT code (never `list`) so a prospective member
      // can request to join and poll whether the head approved them. Codes are
      // random and unlistable, so they can't be enumerated.
      allow get: if signedIn();

      // The creator becomes the head and the sole initial member.
      allow create: if signedIn()
        && request.resource.data.ownerEmail == email()
        && request.resource.data.memberEmails.hasOnly([email()]);

      // Only the head edits the family doc — rename, and approve/remove members
      // by editing memberEmails. `ownerEmail` can NEVER change once set: this is
      // what blocks a code-holder from making themselves the head.
      //
      // The second branch heals legacy ownerless families: an ALREADY-APPROVED
      // member (in memberEmails — a code-holder who hasn't been approved is not)
      // may stamp THEIR OWN email as the head, one time. Once set, only the
      // first branch applies, so the owner is immutable again.
      allow update: if (isOwner() && ownerUnchanged())
        || (ownerless() && isMember() && claimingSelfAsOwner());

      // Only the head can delete the whole family.
      allow delete: if isOwner();

      // Roster + roles — HEAD ONLY. Stops any member from minting an
      // "Owner"/"Child" record, changing roles, or removing the head.
      match /members/{docId} {
        allow read: if isFamilyMember() || isFamilyOwner();
        allow write: if isFamilyOwner();
      }

      // Shared finances — every approved member can read and write.
      match /wallet/{docId} {
        allow read, write: if isFamilyMember() || isFamilyOwner();
      }
      match /ledger/{docId} {
        allow read, write: if isFamilyMember() || isFamilyOwner();
      }

      // Join requests — a prospective member files ONE for themselves; the head
      // reads them to approve and deletes them to approve or decline. A member
      // can only ever see/cancel their own request.
      match /joinRequests/{reqId} {
        allow read: if isFamilyOwner()
          || (signedIn() && resource.data.email == email());
        allow create: if signedIn()
          && request.resource.data.email == email();
        allow delete: if isFamilyOwner()
          || (signedIn() && resource.data.email == email());
        allow update: if false; // requests are immutable — cancel + refile
      }
    }
  }
}
