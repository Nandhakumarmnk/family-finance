# Copy to .env for local runs, or set these as Cloud Functions env vars on deploy.

# OAuth Web client (same one used by the app's GOOGLE_SERVER_CLIENT_ID).
GOOGLE_CLIENT_ID=821904610076-xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-web-client-secret

# Auth-code redirect used to redeem the app's serverAuthCode.
# 'postmessage' works for the web sign-in flow. Leave as-is unless you hit
# redirect_uri_mismatch (then see DEPLOY.md).
OAUTH_REDIRECT=postmessage

# Transactional email (Resend — https://resend.com, free tier).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Must be a verified sender/domain in Resend. For quick testing you can use
# onboarding@resend.dev (only delivers to your own account email).
REPORT_FROM=Family Finance <onboarding@resend.dev>
